{
  "name": "drizby",
  "version": "0.1.18",
  "description": "Configurable BI platform powered by drizzle-cube",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc --project tsconfig.client.json && vite build",
    "build:server": "tsx scripts/build-server.ts",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "setup": "npm run db:generate && npm run db:migrate && npm run db:seed",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "dependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@aws-sdk/client-rds-data": "^3.1006.0",
    "@aws-sdk/credential-providers": "^3.1006.0",
    "@aws/aurora-dsql-node-postgres-connector": "^0.1.8",
    "@casl/ability": "^6.8.0",
    "@electric-sql/pglite": "^0.3.16",
    "@hono/node-server": "^1.8.0",
    "@jmondi/oauth2-server": "^4.2.2",
    "@libsql/client": "^0.17.0",
    "@monaco-editor/react": "^4.7.0",
    "@neondatabase/serverless": "^1.0.2",
    "@nivo/heatmap": "^0.99.0",
    "@planetscale/database": "^1.19.0",
    "@tanstack/react-query": "^5.0.0",
    "@tidbcloud/serverless": "^0.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.18.0",
    "arctic": "^3.7.0",
    "better-sqlite3": "^12.6.2",
    "d3": "^7.9.0",
    "dotenv": "^17.2.1",
    "drizzle-cube": "^0.4.29",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.45.0",
    "duckdb": "^1.4.4",
    "hono": "^4.0.0",
    "mysql2": "^3.19.1",
    "openai": ">=4.0.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.0",
    "react-grid-layout": "^2.1.1",
    "react-is": "^19.2.3",
    "react-resizable": "^3.0.0",
    "react-router-dom": "^6.8.0",
    "recharts": "^3.5.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@types/react-grid-layout": "^1.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.4",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "bi",
    "analytics",
    "drizzle-cube",
    "semantic-layer",
    "dashboard"
  ],
  "license": "MIT"
}
