{
  "name": "dc-bi",
  "version": "0.1.0",
  "description": "Configurable BI platform powered by drizzle-cube",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client",
    "build:client": "tsc --project tsconfig.client.json && vite build",
    "start": "node dist/index.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "setup": "npm run docker:up && sleep 5 && npm run db:generate && npm run db:migrate && npm run db:seed",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.8.0",
    "@nivo/heatmap": "^0.99.0",
    "@tanstack/react-query": "^5.0.0",
    "arctic": "^3.7.0",
    "dotenv": "^17.2.1",
    "drizzle-cube": "^0.4.22",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.0.0",
    "openai": "^6.25.0",
    "postgres": "^3.4.0",
    "react-grid-layout": "^2.1.1",
    "react-resizable": "^3.0.0",
    "react-router-dom": "^6.8.0",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@types/react-grid-layout": "^1.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.31.4",
    "postcss": "^8.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.4",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "keywords": [
    "bi",
    "analytics",
    "drizzle-cube",
    "semantic-layer",
    "dashboard"
  ],
  "license": "MIT"
}
